generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BusinessRole {
  ADMIN
  STAFF
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum AiGenerationType {
  SERVICE_DESCRIPTION
  CUSTOMER_REPLY
  BUSINESS_SUMMARY
  BUSINESS_INSIGHTS
  TRANSLATION
  MARKETING_COPY
}

enum AiGenerationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AiApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
  NO_SHOW
}

enum BookingSource {
  PUBLIC
  DASHBOARD
  AI_ASSISTANT
}

enum BookingPaymentMethod {
  CARD
  BUSINESS_LOCATION
}

enum BookingPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum BookingPaymentAuditAction {
  CONFIRMED
  MARKED_UNPAID
}

enum ServiceType {
  BOOKING
  MEMBERSHIP
}

enum MembershipBillingInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum MembershipStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum MembershipPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum MembershipPaymentProvider {
  MANUAL
  STRIPE
}

enum PlatformPlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

enum WebhookProcessingStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELED
  BOOKING_COMPLETED
  BOOKING_NO_SHOW
  SUBSCRIPTION_ACTIVE
  SUBSCRIPTION_PAST_DUE
  SUBSCRIPTION_CANCELED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  TEAM_INVITATION
  TEAM_MEMBER_JOINED
  REVIEW_SUBMITTED
}

enum NotificationAudience {
  BUSINESS
  CUSTOMER
  TEAM
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum AuditAction {
  BUSINESS_STATUS_CHANGED
  SUPER_ADMIN_CREATED
  USER_PLATFORM_ROLE_CHANGED
  TEAM_INVITATION_SENT
  TEAM_INVITATION_REVOKED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_ROLE_CHANGED
  TEAM_MEMBER_REMOVED
  TEAM_MEMBER_SERVICES_CHANGED
  TEAM_MEMBER_AVAILABILITY_CHANGED
  BOOKING_ASSIGNED
  REVIEW_STATUS_CHANGED
  AI_GENERATION_REQUESTED
  AI_GENERATION_REVIEWED
  AI_CONTENT_APPLIED
}

enum AuditTargetType {
  BUSINESS
  USER
  TEAM_INVITATION
  TEAM_MEMBER
  BOOKING
  REVIEW
  AI_GENERATION
}

model User {
  id                      String               @id @default(auto()) @map("_id") @db.ObjectId
  name                    String?
  email                   String?              @unique
  emailVerified           DateTime?
  image                   String?
  phone                   String?
  locale                  String?
  timezone                String?
  passwordHash            String?
  platformRole            PlatformRole         @default(USER)
  customerPortalEnabled   Boolean              @default(false)
  customerEmailNotifications Boolean           @default(true)
  customerBookingReminders   Boolean           @default(true)
  customerMarketingOptIn     Boolean           @default(false)
  accounts                Account[]
  sessions                Session[]
  resetTokens             PasswordResetToken[]
  ownedBusinesses         Business[]           @relation("BusinessOwner")
  customerProfiles        Customer[]           @relation("CustomerUser")
  createdBookings         Booking[]            @relation("BookingCreatedBy")
  auditLogs               AuditLog[]           @relation("AuditActor")
  bookingPaymentAudits    BookingPaymentAudit[] @relation("BookingPaymentAuditActor")
  businessMemberships     BusinessMembership[] @relation("MembershipUser")
  invitedMemberships      BusinessMembership[] @relation("MembershipInvitedBy")
  sentTeamInvitations     TeamInvitation[]     @relation("TeamInvitationInvitedBy")
  acceptedTeamInvitations TeamInvitation[]     @relation("TeamInvitationAcceptedBy")
  moderatedReviews        Review[]             @relation("ReviewModeratedBy")
  aiGenerations           AiGeneration[]       @relation("AiGenerationCreatedBy")
  reviewedAiGenerations   AiGeneration[]       @relation("AiGenerationReviewedBy")
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([platformRole, createdAt])
  @@index([customerPortalEnabled, createdAt])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id                    String                      @id @default(auto()) @map("_id") @db.ObjectId
  userId                String                      @db.ObjectId
  tokenHash             String                      @unique
  expiresAt             DateTime
  usedAt                DateTime?
  deliveryStatus        NotificationDeliveryStatus?
  deliveryAttempts      Int?                        @default(0)
  lastDeliveryAttemptAt DateTime?
  sentAt                DateTime?
  providerMessageId     String?
  lastError             String?
  user                  User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime                    @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, usedAt, expiresAt])
  @@index([deliveryStatus, createdAt])
}

model Business {
  id                      String                   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId                 String                   @db.ObjectId
  slug                    String                   @unique
  name                    String
  legalName               String?
  description             String?
  industry                String?
  website                 String?
  email                   String?
  phone                   String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  country                 String?
  logoUrl                 String?
  stripeCustomerId        String?
  status                  BusinessStatus           @default(ACTIVE)
  timezone                String                   @default("UTC")
  currency                String                   @default("usd")
  locale                  String                   @default("en")
  owner                   User                     @relation("BusinessOwner", fields: [ownerId], references: [id])
  settings                BusinessSettings?
  services                Service[]
  membershipPlans         MembershipPlan[]
  customerMemberships     CustomerMembership[]
  membershipPayments      MembershipPayment[]
  bookings                Booking[]
  bookingPayments         BookingPayment[]
  bookingPaymentAudits    BookingPaymentAudit[]
  bookingOccupancies      BookingOccupancy[]
  customers               Customer[]
  availabilities          Availability[]
  unavailableDates        UnavailableDate[]
  subscriptions           Subscription[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  memberships             BusinessMembership[]
  teamInvitations         TeamInvitation[]
  staffServiceAssignments StaffServiceAssignment[]
  staffAvailabilities     StaffAvailability[]
  reviews                 Review[]
  aiGenerations           AiGeneration[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([stripeCustomerId])
  @@index([status])
  @@index([status, createdAt])
  @@index([industry])
  @@index([createdAt])
}

model BusinessSettings {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId            String   @unique @db.ObjectId
  bookingLeadTimeMin    Int      @default(120)
  bookingWindowDays     Int      @default(30)
  cancellationWindowMin Int      @default(1440)
  allowGuestBookings    Boolean  @default(true)
  autoConfirmBookings   Boolean  @default(false)
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Service {
  id               String                   @id @default(auto()) @map("_id") @db.ObjectId
  businessId       String                   @db.ObjectId
  name             String
  slug             String
  type             ServiceType              @default(BOOKING)
  description      String?
  durationMin      Int
  bufferBeforeMin  Int                      @default(0)
  bufferAfterMin   Int                      @default(0)
  priceCents       Int?
  currency         String                   @default("usd")
  requiresPayment  Boolean                  @default(false)
  isActive         Boolean                  @default(true)
  sortOrder        Int                      @default(0)
  business         Business                 @relation(fields: [businessId], references: [id])
  bookings         Booking[]
  membershipPlans  MembershipPlan[]
  availabilities   Availability[]
  unavailableDates UnavailableDate[]
  staffAssignments StaffServiceAssignment[]
  reviews          Review[]
  aiGenerations    AiGeneration[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, isActive])
  @@index([businessId, type, isActive])
  @@index([businessId, sortOrder])
  @@index([businessId, createdAt])
  @@index([businessId, requiresPayment])
}

model Customer {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  businessId     String    @db.ObjectId
  userId         String?   @db.ObjectId
  name           String
  email          String
  phone          String?
  stripeCustomerId String?
  notes          String?
  locale         String?
  timezone       String?
  marketingOptIn Boolean   @default(false)
  business       Business  @relation(fields: [businessId], references: [id])
  user           User?     @relation("CustomerUser", fields: [userId], references: [id])
  bookings       Booking[]
  bookingPayments BookingPayment[]
  memberships    CustomerMembership[]
  membershipPayments MembershipPayment[]
  reviews        Review[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
  @@index([businessId, createdAt])
  @@index([businessId, updatedAt])
  @@index([businessId, marketingOptIn])
  @@index([userId])
  @@index([stripeCustomerId])
}

model MembershipPlan {
  id               String                     @id @default(auto()) @map("_id") @db.ObjectId
  businessId       String                     @db.ObjectId
  serviceId        String?                    @db.ObjectId
  name             String
  slug             String
  description      String?
  features         Json?
  priceCents       Int
  currency         String                     @default("usd")
  billingInterval  MembershipBillingInterval  @default(MONTHLY)
  durationDays     Int                        @default(30)
  trialDays        Int                        @default(0)
  maxActiveMembers Int?
  requiresPayment  Boolean                    @default(true)
  isActive         Boolean                    @default(true)
  sortOrder        Int                        @default(0)
  stripePriceId    String?
  business         Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service          Service?                   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  memberships      CustomerMembership[]
  payments         MembershipPayment[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, isActive])
  @@index([businessId, sortOrder])
  @@index([businessId, billingInterval])
  @@index([serviceId])
  @@index([stripePriceId])
}

model CustomerMembership {
  id                         String                    @id @default(auto()) @map("_id") @db.ObjectId
  businessId                 String                    @db.ObjectId
  customerId                 String                    @db.ObjectId
  planId                     String                    @db.ObjectId
  status                     MembershipStatus          @default(PENDING)
  startsAt                   DateTime
  endsAt                     DateTime
  nextBillingAt              DateTime?
  autoRenew                  Boolean                   @default(false)
  cancelAtPeriodEnd          Boolean                   @default(false)
  canceledAt                 DateTime?
  cancellationReason         String?
  expiredAt                  DateTime?
  renewedAt                  DateTime?
  renewalCount               Int                       @default(0)
  planNameSnapshot           String
  planPriceCentsSnapshot     Int
  planCurrencySnapshot       String
  planIntervalSnapshot       MembershipBillingInterval
  planDurationDaysSnapshot   Int
  providerSubscriptionId     String?
  business                   Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer                   Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan                       MembershipPlan            @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments                   MembershipPayment[]
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, status, endsAt])
  @@index([businessId, planId, status])
  @@index([customerId])
  @@index([customerId, status, endsAt])
  @@index([planId])
  @@index([providerSubscriptionId])
}

model MembershipPayment {
  id                   String                  @id @default(auto()) @map("_id") @db.ObjectId
  businessId           String                  @db.ObjectId
  customerId           String                  @db.ObjectId
  planId               String                  @db.ObjectId
  membershipId         String?                 @db.ObjectId
  amountCents          Int
  currency             String                  @default("usd")
  status               MembershipPaymentStatus @default(PENDING)
  provider             MembershipPaymentProvider @default(MANUAL)
  providerPaymentId    String?
  idempotencyKey       String
  description          String?
  paidAt               DateTime?
  failedAt             DateTime?
  refundedAt           DateTime?
  metadata             Json?
  business             Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer             Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan                 MembershipPlan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  membership           CustomerMembership?     @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@unique([businessId, idempotencyKey])
  @@index([businessId])
  @@index([businessId, status, createdAt])
  @@index([businessId, paidAt])
  @@index([customerId])
  @@index([planId])
  @@index([membershipId])
  @@index([provider, providerPaymentId])
}

model Booking {
  id                         String              @id @default(auto()) @map("_id") @db.ObjectId
  businessId                 String              @db.ObjectId
  serviceId                  String              @db.ObjectId
  customerId                 String              @db.ObjectId
  createdByUserId            String?             @db.ObjectId
  assignedMemberId           String?             @db.ObjectId
  bookingNumber              String
  idempotencyKey             String
  customerAccessTokenHash    String
  customerName               String
  customerEmail              String
  customerPhone              String?
  serviceNameSnapshot        String
  serviceDurationMinSnapshot Int
  servicePriceCentsSnapshot  Int?
  serviceCurrencySnapshot    String
  bufferBeforeMinSnapshot    Int                 @default(0)
  bufferAfterMinSnapshot     Int                 @default(0)
  paymentRequiredSnapshot    Boolean             @default(false)
  startsAt                   DateTime
  endsAt                     DateTime
  timezone                   String
  status                     BookingStatus       @default(PENDING)
  source                     BookingSource       @default(PUBLIC)
  notes                      String?
  internalNotes              String?
  cancellationReason         String?
  canceledAt                 DateTime?
  confirmedAt                DateTime?
  completedAt                DateTime?
  payment                   BookingPayment?
  paymentAudits             BookingPaymentAudit[]
  business                   Business            @relation(fields: [businessId], references: [id])
  service                    Service             @relation(fields: [serviceId], references: [id])
  customer                   Customer            @relation(fields: [customerId], references: [id])
  createdByUser              User?               @relation("BookingCreatedBy", fields: [createdByUserId], references: [id])
  assignedMember             BusinessMembership? @relation("BookingAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  occupancies                BookingOccupancy[]
  notifications              Notification[]
  review                     Review?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  @@unique([businessId, bookingNumber])
  @@unique([businessId, idempotencyKey])
  @@index([businessId])
  @@index([businessId, startsAt])
  @@index([businessId, status])
  @@index([businessId, status, startsAt])
  @@index([businessId, serviceId, startsAt])
  @@index([businessId, customerEmail])
  @@index([businessId, createdAt])
  @@index([businessId, source])
  @@index([serviceId])
  @@index([customerId])
  @@index([assignedMemberId])
  @@index([businessId, assignedMemberId, startsAt])
}

model BookingPayment {
  id                    String                @id @default(auto()) @map("_id") @db.ObjectId
  bookingId             String                @unique @db.ObjectId
  businessId            String                @db.ObjectId
  customerId            String                @db.ObjectId
  amountCents           Int
  currency              String                @default("usd")
  method                BookingPaymentMethod
  status                BookingPaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeCheckoutSessionId String?
  paidAt                DateTime?
  failedAt              DateTime?
  metadata              Json?
  audits                BookingPaymentAudit[]
  booking               Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  business              Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer              Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([businessId, status, createdAt])
  @@index([customerId])
  @@index([stripePaymentIntentId])
  @@index([stripeCheckoutSessionId])
}

model BookingPaymentAudit {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId         String                   @db.ObjectId
  bookingPaymentId  String                   @db.ObjectId
  businessId        String                   @db.ObjectId
  actorUserId       String                   @db.ObjectId
  action            BookingPaymentAuditAction
  paymentStatus     BookingPaymentStatus
  paymentMethod     BookingPaymentMethod
  notes             String?
  booking           Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingPayment    BookingPayment            @relation(fields: [bookingPaymentId], references: [id], onDelete: Cascade)
  business          Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actor             User                     @relation("BookingPaymentAuditActor", fields: [actorUserId], references: [id])
  createdAt         DateTime                 @default(now())

  @@index([bookingId, createdAt])
  @@index([businessId, createdAt])
  @@index([actorUserId, createdAt])
}

model BusinessMembership {
  id                 String                   @id @default(auto()) @map("_id") @db.ObjectId
  businessId         String                   @db.ObjectId
  userId             String                   @db.ObjectId
  invitedByUserId    String?                  @db.ObjectId
  role               BusinessRole
  isActive           Boolean                  @default(true)
  joinedAt           DateTime                 @default(now())
  business           Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user               User                     @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy          User?                    @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  serviceAssignments StaffServiceAssignment[]
  availability       StaffAvailability[]
  assignedBookings   Booking[]                @relation("BookingAssignedMember")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([businessId, userId])
  @@index([businessId, isActive, role])
  @@index([userId, isActive])
  @@index([invitedByUserId])
}

model TeamInvitation {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  businessId       String               @db.ObjectId
  email            String
  role             BusinessRole
  tokenHash        String               @unique
  status           TeamInvitationStatus @default(PENDING)
  expiresAt        DateTime
  invitedByUserId  String               @db.ObjectId
  acceptedByUserId String?              @db.ObjectId
  acceptedAt       DateTime?
  business         Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy        User                 @relation("TeamInvitationInvitedBy", fields: [invitedByUserId], references: [id])
  acceptedBy       User?                @relation("TeamInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([businessId, email])
  @@index([businessId, status, expiresAt])
  @@index([email, status])
  @@index([invitedByUserId])
  @@index([acceptedByUserId])
}

model StaffServiceAssignment {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  businessId   String             @db.ObjectId
  membershipId String             @db.ObjectId
  serviceId    String             @db.ObjectId
  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  membership   BusinessMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  service      Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())

  @@unique([membershipId, serviceId])
  @@index([businessId, membershipId])
  @@index([businessId, serviceId])
  @@index([serviceId])
}

model StaffAvailability {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  businessId   String             @db.ObjectId
  membershipId String             @db.ObjectId
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  isActive     Boolean            @default(true)
  business     Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  membership   BusinessMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([businessId, membershipId, dayOfWeek])
  @@index([membershipId, isActive])
}

model Review {
  id                   String       @id @default(auto()) @map("_id") @db.ObjectId
  businessId           String       @db.ObjectId
  bookingId            String       @unique @db.ObjectId
  customerId           String       @db.ObjectId
  serviceId            String       @db.ObjectId
  moderatedByUserId    String?      @db.ObjectId
  rating               Int
  title                String?
  comment              String
  customerNameSnapshot String
  serviceNameSnapshot  String
  status               ReviewStatus @default(PENDING)
  publishedAt          DateTime?
  moderatedAt          DateTime?
  business             Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking              Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer             Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service              Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  moderatedBy          User?        @relation("ReviewModeratedBy", fields: [moderatedByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([businessId, status, createdAt])
  @@index([businessId, rating])
  @@index([serviceId, status])
  @@index([customerId])
  @@index([moderatedByUserId])
}

model AiGeneration {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  businessId          String             @db.ObjectId
  createdByUserId     String             @db.ObjectId
  reviewedByUserId    String?            @db.ObjectId
  serviceId           String?            @db.ObjectId
  type                AiGenerationType
  status              AiGenerationStatus @default(PENDING)
  approvalStatus      AiApprovalStatus   @default(PENDING)
  prompt              String
  inputContext        Json?
  output              String?
  model               String?
  providerResponseId  String?
  inputTokens         Int                @default(0)
  outputTokens        Int                @default(0)
  totalTokens         Int                @default(0)
  estimatedCostMicros Int?
  creditCost          Int                @default(1)
  errorCode           String?
  errorMessage        String?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  appliedAt           DateTime?
  business            Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy           User               @relation("AiGenerationCreatedBy", fields: [createdByUserId], references: [id])
  reviewedBy          User?              @relation("AiGenerationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  service             Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([businessId, createdAt])
  @@index([businessId, status, createdAt])
  @@index([businessId, approvalStatus, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([reviewedByUserId])
  @@index([serviceId])
}

model BookingOccupancy {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId  String   @db.ObjectId
  bookingId   String   @db.ObjectId
  resourceKey String   @default("BUSINESS")
  bucketStart DateTime
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([businessId, resourceKey, bucketStart])
  @@index([businessId, bucketStart])
  @@index([bookingId])
}

model Availability {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  businessId      String    @db.ObjectId
  serviceId       String?   @db.ObjectId
  dayOfWeek       DayOfWeek
  startTime       String
  endTime         String
  slotDurationMin Int       @default(30)
  bufferBeforeMin Int       @default(0)
  bufferAfterMin  Int       @default(0)
  isActive        Boolean   @default(true)
  business        Business  @relation(fields: [businessId], references: [id])
  service         Service?  @relation(fields: [serviceId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([businessId])
  @@index([businessId, dayOfWeek])
  @@index([businessId, dayOfWeek, isActive])
  @@index([businessId, serviceId, dayOfWeek])
  @@index([businessId, serviceId, isActive])
  @@index([serviceId])
}

model UnavailableDate {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId String   @db.ObjectId
  serviceId  String?  @db.ObjectId
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  isFullDay  Boolean  @default(false)
  business   Business @relation(fields: [businessId], references: [id])
  service    Service? @relation(fields: [serviceId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId, startsAt])
  @@index([businessId, startsAt, endsAt])
  @@index([businessId, serviceId, startsAt])
  @@index([businessId, isFullDay])
  @@index([serviceId])
}

model Subscription {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  businessId           String             @db.ObjectId
  platformPlanId       String?            @db.ObjectId
  planCode             String?            // Legacy compatibility; new writes use platformPlanId.
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  stripeProductId      String?
  latestInvoiceId      String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  lastPaymentAt        DateTime?
  lastPaymentFailedAt  DateTime?
  business             Business           @relation(fields: [businessId], references: [id])
  platformPlan         PlatformPlan?      @relation(fields: [platformPlanId], references: [id], onDelete: Restrict)
  notifications        Notification[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([businessId])
  @@index([platformPlanId])
  @@index([businessId, createdAt])
  @@index([planCode])
  @@index([status])
  @@index([status, updatedAt])
  @@index([planCode, status, updatedAt])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model PlatformPlan {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  code             String            @unique
  name             String
  monthlyPriceCents Int              @default(0)
  yearlyPriceCents  Int?
  description      String?
  features         Json?
  trialDays        Int               @default(0)
  limits           Json?
  aiFeatures       Json?
  prioritySupport  Boolean           @default(false)
  stripePriceId    String?
  stripeProductId  String?
  status           PlatformPlanStatus @default(ACTIVE)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subscriptions    Subscription[]

  @@index([status, sortOrder])
}

model Notification {
  id             String                     @id @default(auto()) @map("_id") @db.ObjectId
  businessId     String                     @db.ObjectId
  bookingId      String?                    @db.ObjectId
  subscriptionId String?                    @db.ObjectId
  dedupeKey      String                     @unique
  type           NotificationType
  audience       NotificationAudience
  channel        NotificationChannel
  deliveryStatus NotificationDeliveryStatus @default(PENDING)
  recipientEmail String?
  title          String
  message        String
  actionUrl      String?
  metadata       Json?
  readAt         DateTime?
  sentAt         DateTime?
  lastAttemptAt  DateTime?
  attempts       Int                        @default(0)
  lastError      String?
  business       Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking        Booking?                   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  subscription   Subscription?              @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([businessId, createdAt])
  @@index([businessId, audience, channel, createdAt])
  @@index([businessId, audience, channel, readAt, createdAt])
  @@index([businessId, channel, deliveryStatus, createdAt])
  @@index([bookingId])
  @@index([subscriptionId])
}

model AuditLog {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  actorUserId String          @db.ObjectId
  businessId  String?         @db.ObjectId
  action      AuditAction
  targetType  AuditTargetType
  targetId    String
  reason      String?
  metadata    Json?
  actor       User            @relation("AuditActor", fields: [actorUserId], references: [id])
  business    Business?       @relation(fields: [businessId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())

  @@index([actorUserId, createdAt])
  @@index([businessId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([createdAt])
}

model StripeWebhookEvent {
  id            String                  @id @default(auto()) @map("_id") @db.ObjectId
  stripeEventId String                  @unique
  type          String
  livemode      Boolean
  status        WebhookProcessingStatus @default(PROCESSING)
  attempts      Int                     @default(1)
  lastError     String?
  processedAt   DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([status])
  @@index([createdAt])
}
